# ============================================================
# GROQ API KEY(S) (RECOMMENDED - Fastest option, FREE tier)
# ============================================================
# Get your FREE API key at: https://console.groq.com/keys
# Groq provides ~500 tokens/sec with Llama 3.3 70B
#
# SINGLE KEY (30 req/min = 0.5 req/sec):
# GROQ_API_KEY=gsk_your_api_key_here
#
# MULTIPLE KEYS for higher throughput (recommended for Clay):
# - 2 keys = 60 req/min = 1 req/sec (matches Clay's rate, 0% timeouts)
# - 3 keys = 90 req/min = 1.5 req/sec (faster than Clay)
# - 4 keys = 120 req/min = 2 req/sec (comfortable headroom)
# Create multiple free Groq accounts and add keys comma-separated:
# GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3

# ============================================================
# Hugging Face token (backup fallback)
# ============================================================
# Get a token from: https://huggingface.co/settings/tokens
# HF_TOKEN=hf_your_token_here

# ============================================================
# Optional: Override default settings
# ============================================================
# OLLAMA_BASE_URL=http://localhost:11434/v1
# MAX_CONTEXT_TOKENS=6000
# MAX_REACT_STEPS=5
# LOG_LEVEL=INFO

# ============================================================
# REACHER EMAIL VERIFICATION (Self-hosted)
# ============================================================
# Reacher.email is a self-hosted email verification service
# that performs SMTP verification for high accuracy.
#
# Setup Guide:
# 1. Get a VPS with port 25 open (required for SMTP)
# 2. Install Docker on the VPS
# 3. Run: docker run -d -p 8080:8080 -e RCH__API__SECRET=your_secret reacherhq/backend:latest
# 4. Set the environment variables below
#
# REACHER_API_SECRET=your_api_secret_here
# REACHER_BASE_URL=http://your-vps-ip:8080
#
# Optional settings:
# REACHER_TIMEOUT=30
# REACHER_HELLO_NAME=yourdomain.com
# REACHER_FROM_EMAIL=verify@yourdomain.com
